# Spring Boot 공개 API 주소입니다. 브라우저에 공개되어도 되는 값만 사용합니다.
NEXT_PUBLIC_API_BASE_URL=https://be-test.dshelper.kr

# 실제 API가 기본이며, 로컬에서 백엔드 없이 화면을 확인할 때만 true로 설정합니다.
NEXT_PUBLIC_USE_VOLUNTEER_MOCKS=false

# ACTIVE_MEMBER | NEW_APPLICANT | PENDING_APPLICATION | REJECTED_APPLICATION | SUSPENDED_MEMBER
NEXT_PUBLIC_VOLUNTEER_MOCK_SCENARIO=ACTIVE_MEMBER
